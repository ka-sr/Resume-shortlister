{
  "name": "resume-shortlister",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack resume screening and candidate ranking web application.",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node server/index.js",
